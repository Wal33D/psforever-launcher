<Application x:Class="PSForeverLauncher.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:PSForeverLauncher.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/DarkTheme.xaml" />
                <ResourceDictionary Source="Themes/ButtonStyles.xaml" />
                <ResourceDictionary Source="Themes/TextBoxStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Global Converters -->
            <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
            <converters:FactionToColorConverter x:Key="FactionToColor" />
            <converters:ServerStateToColorConverter x:Key="StateToColor" />
            <converters:ServerStateToTextConverter x:Key="StateToText" />
            <converters:StringToVisibilityConverter x:Key="StringToVisConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
