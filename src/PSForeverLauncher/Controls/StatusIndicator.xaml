<UserControl x:Class="PSForeverLauncher.Controls.StatusIndicator"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:PSForeverLauncher.Converters">
    <UserControl.Resources>
        <converters:ServerStateToColorConverter x:Key="StateToColorConverter" />
        <converters:ServerStateToTextConverter x:Key="StateToTextConverter" />
    </UserControl.Resources>
    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
        <Ellipse Width="8" Height="8"
                 Fill="{Binding State, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource StateToColorConverter}}"
                 Margin="0,0,6,0" />
        <TextBlock Text="{Binding State, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource StateToTextConverter}}"
                   Foreground="{Binding State, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource StateToColorConverter}}"
                   FontSize="12" FontWeight="SemiBold" />
    </StackPanel>
</UserControl>
