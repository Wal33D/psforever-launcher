<UserControl x:Class="PSForeverLauncher.Controls.ServerCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:PSForeverLauncher.Controls">
    <Border Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1" CornerRadius="8"
            Padding="20,16" Margin="0,0,0,12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Server Name + Address -->
            <StackPanel Grid.Row="0" Grid.Column="0">
                <TextBlock Text="{Binding ServerName}"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="18" FontWeight="SemiBold" />
                <TextBlock Text="{Binding Address}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12" Margin="0,2,0,0" />
            </StackPanel>

            <!-- Play Button -->
            <Button Grid.Row="0" Grid.Column="1" Grid.RowSpan="3"
                    Content="PLAY"
                    Style="{StaticResource PlayButton}"
                    Command="{Binding PlayCommand}"
                    VerticalAlignment="Center" />

            <!-- Status + Player Count -->
            <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal"
                        Margin="0,10,0,0">
                <controls:StatusIndicator State="{Binding ConnectionState}" />
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12" Margin="12,0,0,0"
                           VerticalAlignment="Center">
                    <Run Text="{Binding PlayerCount, Mode=OneWay}" />
                    <Run Text=" players" />
                </TextBlock>
            </StackPanel>

            <!-- Faction Breakdown -->
            <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal"
                        Margin="0,8,0,0">
                <controls:FactionBadge Faction="TR" Count="{Binding TRCount}" Margin="0,0,6,0" />
                <controls:FactionBadge Faction="NC" Count="{Binding NCCount}" Margin="0,0,6,0" />
                <controls:FactionBadge Faction="VS" Count="{Binding VSCount}" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
