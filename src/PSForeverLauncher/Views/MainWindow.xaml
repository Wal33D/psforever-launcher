<Window x:Class="PSForeverLauncher.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:PSForeverLauncher.Views"
        xmlns:converters="clr-namespace:PSForeverLauncher.Converters"
        Title="PSForever Launcher"
        Width="900" Height="600"
        MinWidth="700" MinHeight="450"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Border Background="{StaticResource BackgroundBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32" />  <!-- Title Bar -->
                <RowDefinition Height="*" />   <!-- Content -->
                <RowDefinition Height="28" />  <!-- Status Bar -->
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Grid Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Logo / Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="12,0,0,0"
                            VerticalAlignment="Center">
                    <TextBlock Text="&#xE7FC;" FontFamily="Segoe MDL2 Assets"
                               Foreground="{StaticResource AccentBrush}"
                               FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="PSForever Launcher"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="12" FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Window Controls -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="&#xE921;" Style="{StaticResource TitleBarButton}"
                            Click="MinimizeButton_Click" />
                    <Button Content="&#xE922;" Style="{StaticResource TitleBarButton}"
                            Click="MaximizeButton_Click" />
                    <Button Content="&#xE8BB;" Style="{StaticResource CloseButton}"
                            Click="CloseButton_Click" />
                </StackPanel>
            </Grid>

            <!-- Main Content -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="1" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Navigation Sidebar -->
                <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}">
                    <StackPanel Margin="0,12,0,0">
                        <Button Content="&#xE774;  Servers" Style="{StaticResource NavButton}"
                                Command="{Binding ShowServersCommand}" />
                        <Button Content="&#xE77B;  Players" Style="{StaticResource NavButton}"
                                Command="{Binding ShowPlayersCommand}" />
                        <Button Content="&#xE713;  Settings" Style="{StaticResource NavButton}"
                                Command="{Binding ShowSettingsCommand}" />
                    </StackPanel>
                </Border>

                <!-- Separator -->
                <Rectangle Grid.Column="1" Fill="{StaticResource BorderBrush}" />

                <!-- Content Area -->
                <Grid Grid.Column="2" Margin="24,16">
                    <!-- Servers View -->
                    <views:ServerListView DataContext="{Binding ServerList}"
                                          Visibility="{Binding DataContext.ActiveView,
                                              RelativeSource={RelativeSource AncestorType=Window},
                                              Converter={StaticResource StringToVisConverter},
                                              ConverterParameter=Servers}" />

                    <!-- Settings View -->
                    <views:SettingsView DataContext="{Binding Settings}"
                                        Visibility="{Binding DataContext.ActiveView,
                                            RelativeSource={RelativeSource AncestorType=Window},
                                            Converter={StaticResource StringToVisConverter},
                                            ConverterParameter=Settings}" />
                </Grid>
            </Grid>

            <!-- Status Bar -->
            <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                <Grid Margin="12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding VersionText}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11" VerticalAlignment="Center" />

                    <Rectangle Grid.Column="1" Width="1" Fill="{StaticResource BorderBrush}"
                               Margin="12,4" />

                    <TextBlock Grid.Column="2"
                               Text="{Binding GameDetectionText}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11" VerticalAlignment="Center" />

                    <TextBlock Grid.Column="2"
                               Text="{Binding StatusText}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11" VerticalAlignment="Center"
                               HorizontalAlignment="Right" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
