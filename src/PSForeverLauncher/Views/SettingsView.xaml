<UserControl x:Class="PSForeverLauncher.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,20">
            <!-- Header -->
            <TextBlock Text="SETTINGS"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="12" FontWeight="SemiBold"
                       Margin="0,0,0,20"
                       LetterSpacing="1.5" />

            <!-- Game Path -->
            <TextBlock Text="Game Installation"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontSize="16" FontWeight="SemiBold"
                       Margin="0,0,0,12" />

            <Border Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="8"
                    Padding="16" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="PlanetSide Installation Path"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" Margin="0,0,0,8" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding GamePath, Mode=TwoWay}"
                                 Style="{StaticResource DarkTextBox}"
                                 IsReadOnly="True" />
                        <Button Grid.Column="1"
                                Content="Browse..."
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding BrowseGamePathCommand}"
                                Margin="8,0,0,0" />
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Ellipse Width="6" Height="6" Margin="0,0,6,0"
                                 VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource ErrorBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsGameDetected}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource SuccessBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding GameStatus}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Launch Options -->
            <TextBlock Text="Launch Options"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontSize="16" FontWeight="SemiBold"
                       Margin="0,0,0,12" />

            <Border Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="8"
                    Padding="16" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Command Line Arguments"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" Margin="0,0,0,8" />
                    <TextBox Text="{Binding LaunchArgs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource DarkTextBox}" />
                    <TextBlock Text="Default: /K:StagingTest /CC"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11" Margin="0,6,0,0" Opacity="0.7" />
                </StackPanel>
            </Border>

            <!-- Save -->
            <Button Content="Save Settings"
                    Style="{StaticResource PlayButton}"
                    Command="{Binding SaveCommand}"
                    HorizontalAlignment="Left" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
